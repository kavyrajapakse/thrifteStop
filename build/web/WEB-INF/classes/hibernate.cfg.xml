<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC "-//Hibernate/Hibernate Configuration DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
  <session-factory>
    <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>
    <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
    <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/thriftdb?useSSL=false</property>
    <property name="hibernate.connection.username">root</property>
    <property name="hibernate.connection.password">Sethmin2007.</property>
    <property name="hibernate.show_sql">true</property>
    <mapping class="hibernate.User"/>
    <mapping class="hibernate.City"/>
    <mapping class="hibernate.Address"/>
    <mapping class="hibernate.Category"/>
    <mapping class="hibernate.Color"/>
    <mapping class="hibernate.Condition"/>
    <mapping class="hibernate.Size"/>
    <mapping class="hibernate.Status"/>
    <mapping class="hibernate.Product"/>
    <mapping class="hibernate.ProductImage"/>
    <mapping class="hibernate.OrderStatus"/>
    <mapping class="hibernate.OrderItem"/>
    <mapping class="hibernate.CustomerOrder"/>
    <mapping class="hibernate.Cart"/>
    <mapping class="hibernate.ThriftAdmin"/>
  </session-factory>
</hibernate-configuration>


